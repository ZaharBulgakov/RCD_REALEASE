# URL вашего проекта Supabase (можно найти в Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Анонимный ключ API Supabase (можно найти в Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# (Опционально) URL для перенаправления после авторизации. 
# В коде используется window.location.origin, но для локальной разработки 
# иногда полезно иметь возможность переопределить это.
# NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000
